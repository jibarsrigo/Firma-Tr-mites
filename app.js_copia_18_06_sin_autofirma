btnAnalizar.onclick = () => {      // ­ƒæë Inicia el an├ílisis completo de la traza y genera resultados

  // Oculta resultados anteriores


  // Ô£à 1. VALIDACI├ôN M├ëTODO
  if (!metodoClave.checked && !metodoCert.checked) {
    abrirPanel("Validaci├│n", "Debe seleccionar m├®todo");
    return;
  }

  // Ô£à 2. VALIDACI├ôN SISTEMA (ANTES que la traza)
  if (metodoCert.checked && !sisPC.checked && !sisMovil.checked) {
    abrirPanel("Validaci├│n", "Debe seleccionar sistema");
    return;
  }

  // Ô£à 3. VALIDACI├ôN TRAZA
  // ­ƒæë Se obtiene la traza pegada por el usuario
const texto = document.getElementById("inputTraza").value.trim();

  // ­ƒæë IMPORTANTE: Guardar l├¡neas originales ANTES de convertir a may├║sculas.
  // Esto preserva el formato original (tabuladores, espacios, caracteres especiales) 
  // para mostrar los literales de error exactamente como el usuario los peg├│.
const lineasOriginales = texto.split(/\r?\n/);

  // ­ƒæë Se convierte todo a may├║sculas. Evita errores al buscar textos (TR_, literales, etc.)
const traza = texto.toUpperCase();

  // ­ƒæë Si no hay texto ÔåÆ error
if (!texto) {
  abrirPanel("Validaci├│n", "Todav├¡a no ha pegado trazas");
  return;
}
  
// ­ƒæë Si no contiene TR_ ÔåÆ no es traza v├ílida
if (!traza.includes("TR_")) {
  abrirPanel("Validaci├│n", `Esto no es una traza v├ílida`);
  return;
}


// =====================================
// ­ƒö┤ DETECCI├ôN DE EVENTOS TR_
// =====================================

// ­ƒæë Paso 0: dividimos la traza en l├¡neas (ANTES de usarla)
// ­ƒö╣ necesario para fase 9 (orden real)
const lineas = traza.split(/\r?\n/);

// ­ƒæë Extraemos eventos TR_ en ORDEN REAL
// ­ƒö╣ esto nos permite saber cu├íl es el ├║ltimo evento v├ílido
const eventos = lineas
  .filter(linea => linea.includes("TR_"))
  .map(linea => linea.match(/TR_[A-Z]+/)?.[0])
  .filter(Boolean);

// ­ƒæë ├Ültimo evento real del flujo
// ­ƒö╣ controlamos caso sin eventos para evitar error

const ultimoEvento = eventos.length > 0
  ? eventos[eventos.length - 1]
  : null;


// ­ƒæë Detectamos presencia b├ísica (seguimos usando l├│gica actual)
const hayFRI = eventos.includes("TR_FRI");
const hayFRF = eventos.includes("TR_FRF");
const haySGI = eventos.includes("TR_SGI");
const haySGX = eventos.includes("TR_SGX");
const haySGO = eventos.includes("TR_SGO");

// ­ƒö╣ NUEVO: eventos para flujo visual
const eventosFlujo = {
  TR_FRI: hayFRI,
  TR_FRF: hayFRF,
  TR_SGI: haySGI,
  TR_SGX: haySGX,
  TR_SGO: haySGO,
  TR_REG: eventos.includes("TR_REG"),
  TR_FIN: eventos.includes("TR_FIN")
};

  // =====================================
// ­ƒö┤ CONTEXTO DE FLUJO (PASO 1)
// =====================================
// ­ƒæë NO sustituye l├│gica actual
// ­ƒæë Solo encapsula el flujo en un objeto reutilizable

const contexto = {
  llegaFirma: haySGI,
  errorPreFirma: hayFRF && !haySGI,
  errorFirma: haySGX,
  firmaOK: haySGO,
  hayFinFormulario: hayFRF
};


// ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ
// ­ƒö╣ FASE DEL FLUJO (PASO 3)
// ÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇ
// Aqu├¡ damos un paso m├ís: no solo booleanos,
// ahora clasificamos el estado del tr├ímite en una "fase"
// Esto nos permitir├í simplificar el ├írbol en siguientes versiones

// ­ƒæë Fase basada en ├║ltimo evento (seguro)

if (!ultimoEvento) {

  // ­ƒæë No hay eventos ÔåÆ tratamos como pre_firma
  contexto.fase = "pre_firma";
}
else if (ultimoEvento === "TR_FRF") {
  contexto.fase = "pre_firma";
}
else if (ultimoEvento === "TR_SGX") {
  contexto.fase = "error_firma";
}
else if (ultimoEvento === "TR_SGO") {
  contexto.fase = "firma_ok";
}
else {
  // ­ƒæë fallback seguridad
  if (!contexto.llegaFirma) {
    contexto.fase = "pre_firma";
  } else if (contexto.errorFirma) {
    contexto.fase = "error_firma";
  } else if (contexto.firmaOK) {
    contexto.fase = "firma_ok";
  } else {
    contexto.fase = "desconocida";
  }
}


  

// DEBUG para ver claramente en qu├® fase est├í cada traza
console.log("FASE:", contexto.fase);

  
  

// ­ƒöì DEBUG
console.log("CONTEXTO:", contexto);


